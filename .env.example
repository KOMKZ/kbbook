# KBBook Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Site identity
VITE_SITE_NAME=KBBook
VITE_SITE_TAGLINE=Your Knowledge, in Book Form
VITE_GITHUB_URL=https://github.com/KOMKZ/kbbook

# OSS (Alibaba Cloud Object Storage)
# Required for: make upload-to-oss, tablet sync
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_BUCKET=
OSS_PATH=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Network
# Default server URL for network mode
NETWORK_URL=http://localhost:3004
